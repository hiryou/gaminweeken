u0_a77
$ termux-wake-lock	# run once to allow termux app running in background

$ mkdir -p ~/.termux/boot
cat > ~/.termux/boot/start_ssh.sh <<'EOF'
#!/data/data/com.termux/files/usr/bin/sh
termux-wake-lock
sshd
EOF
chmod +x ~/.termux/boot/start_ssh.sh

# (via scrcpy), GUI: Launch the Termux:Boot app from your Android application drawer at least once manually. This
# registers the application with the system's startup triggers. <- this step is very crucial to make it work!


