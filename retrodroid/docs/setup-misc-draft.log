#  - packages-cf.termux.dev
$ apt clean
$ app update
$ pkg install rsync openssh -y

then rsync, create folder path on the fly at destination
$ rsync -avzu --exclude='.DS_Store' --exclude='_ignore' -e 'ssh -p 8022' --rsync-path='mkdir -p /sdcard/Download/retrodroid/scripts && rsync' scripts/ u0_a77@192.168.0.99:/sdcard/Download/retrodroid/scripts/

then run like this
$ bash controller.sh


