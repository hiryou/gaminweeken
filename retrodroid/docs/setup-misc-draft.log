# watching CPU temp
# watch -n 2 'cat /sys/class/thermal/thermal_zone*/temp'
watch -n 2 'for z in /sys/class/thermal/thermal_zone*; do echo -n "$(basename "$z") "; awk "{printf \"%.1f°C\n\", \$1/1000}" "$z/temp"; done'
# rules:
# 55000 = 55°C
# 70000 = 70°C
# 85000 = 85°C
# <60°C   excellent
# 60–70°C fine
# 70–80°C warm but okay
# 80–85°C caution
# 85°C+   improve cooling / stop heavy test


To disable upon boot Update notification
$ adb shell pm disable-user --user 0 android.rockchip.update.service
$ adb shell pm clear android.rockchip.update.service
$ adb reboot

If the first command says Unknown package, find the actual updater package on your build:
$ adb shell pm list packages | grep -Ei 'rockchip|ota|update|upgrade'

To enable it back:
$ adb shell pm enable android.rockchip.update.service


Need to install rsync on termux
$ termux-change-repo
# Pick Single mirror, then choose either:
